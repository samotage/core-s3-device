// WiFi credentials for the meeting recorder's HTTP server.
//
// Copy this file to `include/secrets.h` and fill in your network.
// `secrets.h` is gitignored and must NEVER be committed (this repo is public).
//
// If secrets.h is absent the firmware still builds — it just runs the recorder
// offline (no WiFi, no HTTP server).

#ifndef __SECRETS_H
#define __SECRETS_H

#define WIFI_SSID    "your-wifi-ssid"
#define WIFI_PASS    "your-wifi-password"

// mDNS hostname — the device is reachable at http://<REC_HOSTNAME>.local
#define REC_HOSTNAME "core-s3"

#endif  // __SECRETS_H
